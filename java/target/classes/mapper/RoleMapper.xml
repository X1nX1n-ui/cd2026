<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.cd.mapper.RoleMapper">

    <resultMap id="RoleResultMap" type="com.cd.entity.Role">
        <id property="id" column="id"/>
        <result property="roleName" column="role_name"/>
        <result property="roleCode" column="role_code"/>
        <result property="description" column="description"/>
        <result property="deleted" column="deleted"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <resultMap id="RoleOptionResultMap" type="com.cd.entity.RoleOption">
        <id property="id" column="id"/>
        <result property="roleName" column="role_name"/>
        <result property="roleCode" column="role_code"/>
    </resultMap>

    <resultMap id="RolePermissionRelationResultMap" type="com.cd.entity.UserRoleRelation">
        <result property="roleId" column="role_id"/>
        <result property="permissionId" column="permission_id"/>
    </resultMap>

    <sql id="BaseColumnList">
        id, role_name, role_code, description, deleted, created_at, updated_at
    </sql>

    <select id="selectPage" resultMap="RoleResultMap">
        SELECT
        <include refid="BaseColumnList"/>
        FROM `role`
        <where>
            deleted = 0
            <if test="roleName != null and roleName != ''">
                AND role_name LIKE CONCAT('%', #{roleName}, '%')
            </if>
        </where>
        ORDER BY id DESC
        LIMIT #{pageSize} OFFSET #{offset}
    </select>

    <select id="count" resultType="long">
        SELECT COUNT(1)
        FROM `role`
        <where>
            deleted = 0
            <if test="roleName != null and roleName != ''">
                AND role_name LIKE CONCAT('%', #{roleName}, '%')
            </if>
        </where>
    </select>

    <select id="selectById" resultMap="RoleResultMap">
        SELECT
        <include refid="BaseColumnList"/>
        FROM `role`
        WHERE id = #{id}
          AND deleted = 0
    </select>

    <select id="selectByCode" resultMap="RoleResultMap">
        SELECT
        <include refid="BaseColumnList"/>
        FROM `role`
        WHERE role_code = #{roleCode}
          AND deleted = 0
        LIMIT 1
    </select>

    <select id="selectByUserId" resultMap="RoleResultMap">
        SELECT r.id, r.role_name, r.role_code, r.description, r.deleted, r.created_at, r.updated_at
        FROM `role` r
                 INNER JOIN user_role ur ON ur.role_id = r.id
        WHERE ur.user_id = #{userId}
          AND r.deleted = 0
        ORDER BY r.id ASC
    </select>

    <select id="selectOptions" resultMap="RoleOptionResultMap">
        SELECT id, role_name, role_code
        FROM `role`
        WHERE deleted = 0
        ORDER BY id ASC
    </select>

    <insert id="insert" parameterType="com.cd.entity.Role" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO `role` (
            role_name,
            role_code,
            description,
            deleted
        ) VALUES (
            #{roleName},
            #{roleCode},
            #{description},
            0
        )
    </insert>

    <update id="update" parameterType="com.cd.entity.Role">
        UPDATE `role`
        <set>
            <if test="roleName != null">role_name = #{roleName},</if>
            <if test="roleCode != null">role_code = #{roleCode},</if>
            <if test="description != null">description = #{description},</if>
            <if test="deleted != null">deleted = #{deleted},</if>
        </set>
        WHERE id = #{id}
          AND deleted = 0
    </update>

    <update id="deleteById">
        UPDATE `role`
        SET deleted = 1
        WHERE id = #{id}
          AND deleted = 0
    </update>

    <select id="selectPermissionIdsByRoleId" resultType="long">
        SELECT permission_id
        FROM role_permission
        WHERE role_id = #{roleId}
    </select>

    <select id="selectRolePermissionRelations" resultMap="RolePermissionRelationResultMap">
        SELECT role_id, permission_id
        FROM role_permission
        WHERE role_id IN
        <foreach collection="roleIds" item="roleId" open="(" separator="," close=")">
            #{roleId}
        </foreach>
    </select>

    <delete id="deleteRolePermissionsByRoleId">
        DELETE FROM role_permission
        WHERE role_id = #{roleId}
    </delete>

    <delete id="deleteUserRolesByRoleId">
        DELETE FROM user_role
        WHERE role_id = #{roleId}
    </delete>

    <insert id="insertRolePermissions">
        INSERT INTO role_permission (role_id, permission_id)
        VALUES
        <foreach collection="permissionIds" item="permissionId" separator=",">
            (#{roleId}, #{permissionId})
        </foreach>
    </insert>
</mapper>
